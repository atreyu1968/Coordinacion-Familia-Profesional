modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 300000

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 20788
externalPort = 3002

[[ports]]
localPort = 20789
externalPort = 3003

[[ports]]
localPort = 22333
externalPort = 3000

[userenv]

[userenv.shared]
JAAS_APP_ID = "vpaas-magic-cookie-e59392d6d00048ea90ea3027a421f6ea"

[nix]
channel = "stable-25_05"
