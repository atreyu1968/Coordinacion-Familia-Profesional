# ===========================================================================
# Coordina ADG — collaborative space stack configuration.
# Copy to .env, fill in the values, then run: docker compose up -d
# Keep the real .env out of version control (it holds passwords).
# ===========================================================================

# Public hostnames (subdomains of your main site so SSO cookies are shared).
# Point both to this server's IP and terminate TLS at the host nginx.
NEXTCLOUD_DOMAIN=drive.tu-dominio.com
COLLABORA_DOMAIN=office.tu-dominio.com

# Local loopback ports the host nginx proxies to (no need to change usually).
NEXTCLOUD_PORT=8081
COLLABORA_PORT=9980

# Nextcloud database (internal to the compose network).
NEXTCLOUD_DB_NAME=nextcloud
NEXTCLOUD_DB_USER=nextcloud
NEXTCLOUD_DB_PASSWORD=change-me-db-password

# Nextcloud administrator. Use these same credentials in the Coordina ADG
# control panel (Espacio colaborativo) so the platform can provision folders.
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=change-me-admin-password

# Collabora admin console (https://office.tu-dominio.com/browser/.../admin).
COLLABORA_ADMIN_USER=admin
COLLABORA_ADMIN_PASSWORD=change-me-collabora-password
