# ===========================================================================
# Coordina ADG — documentation wiki (Outline) stack configuration.
# Copy to .env, fill in the values, then run: docker compose up -d
# Keep the real .env out of version control (it holds passwords/secrets).
# ===========================================================================

# Your main application domain (the OIDC issuer host). Outline authenticates
# against https://<APP_DOMAIN>/api/oidc (SSO with the Coordina ADG login).
APP_DOMAIN=coordinacionag.tu-dominio.com

# The wiki's OWN subdomain. Outline cannot be served from a subpath, so this
# needs its own DNS A/AAAA record pointing at this server, plus its own HTTPS
# certificate (install-outline.sh obtains it via certbot).
OUTLINE_DOMAIN=docs.coordinacionag.tu-dominio.com
OUTLINE_URL=https://docs.coordinacionag.tu-dominio.com

# Whether Outline forces an https redirect. Keep "true" when a TLS certificate is
# in place (recommended — SSO login requires https). The installer sets this to
# "false" and writes an http:// OUTLINE_URL when no certificate is available.
OUTLINE_FORCE_HTTPS=true

# Local loopback port the host nginx proxies to (no need to change usually).
OUTLINE_PORT=3500

# Outline database (internal to the compose network).
OUTLINE_DB_NAME=outline
OUTLINE_DB_USER=outline
OUTLINE_DB_PASSWORD=change-me-db-password

# Two independent 32-byte secrets. Generate each with: openssl rand -hex 32
# Rotating SECRET_KEY logs everyone out; rotating UTILS_SECRET invalidates
# internal tokens. Do NOT reuse the same value for both.
OUTLINE_SECRET_KEY=change-me-openssl-rand-hex-32
OUTLINE_UTILS_SECRET=change-me-openssl-rand-hex-32

# OIDC client Outline uses against the api-server. Use these same values in the
# Coordina ADG control panel (Documentación). The client secret should be a long
# random string: openssl rand -hex 24
OIDC_CLIENT_ID=coordina-outline
OIDC_CLIENT_SECRET=change-me-oidc-client-secret
