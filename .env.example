# ---------------------------------------------------------------------------
# Coordina ADG — environment for the API server (self-hosted / production)
# Copy to ".env" at the repo root. deploy/install.sh generates this for you.
# ---------------------------------------------------------------------------

# Required
NODE_ENV=production
# Internal port the Node API server listens on (nginx proxies to it).
PORT=3001
# PostgreSQL connection string.
DATABASE_URL=postgresql://coordina_adg:CHANGE_ME@127.0.0.1:5432/coordina_adg
# Secret used to sign auth tokens. Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME
# Log level: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# Object storage (self-hosted). "local" stores uploaded files on disk.
STORAGE_DRIVER=local
# Absolute directory for uploaded files (must be writable by the service user).
LOCAL_STORAGE_DIR=/var/lib/coordina-adg/storage
# Leave empty when the API is served from the same origin as the web app
# (the default). Set to an origin like https://example.org only for cross-origin.
PUBLIC_APP_URL=

# ---------------------------------------------------------------------------
# Optional — video calls via JaaS (8x8). If left blank, the app falls back to
# the public meet.jit.si server (no account needed). Provide the private key as
# a single line with literal \n in place of newlines.
# ---------------------------------------------------------------------------
# JAAS_APP_ID=
# JAAS_KID=
# JAAS_PRIVATE_KEY=

# ---------------------------------------------------------------------------
# Optional — transactional email for password resets (Resend). If left blank,
# the "forgot password" flow will not be able to deliver codes.
# ---------------------------------------------------------------------------
# RESEND_API_KEY=
# RESEND_FROM=Coordina ADG <no-reply@example.org>
